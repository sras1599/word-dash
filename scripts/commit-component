#!/usr/bin/env bash
set -euo pipefail

DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) break ;;
  esac
done

if [[ $# -ne 1 ]]; then
  echo "Usage: $(basename "$0") [--dry-run] <ComponentName>" >&2
  exit 1
fi

COMPONENT="$1"
REPO_ROOT="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"

README_PATH="docs/internal/frontend/components/${COMPONENT}.md"
COMPONENT_DIR="frontend/src/components/${COMPONENT}"

# Validate paths exist
if [[ ! -f "${REPO_ROOT}/${README_PATH}" ]]; then
  echo "Error: readme not found at ${README_PATH}" >&2
  exit 1
fi

if [[ ! -d "${REPO_ROOT}/${COMPONENT_DIR}" ]]; then
  echo "Error: component directory not found at ${COMPONENT_DIR}" >&2
  exit 1
fi

if [[ "$DRY_RUN" == true ]]; then
  echo "[dry-run] Would stage: ${README_PATH}"
  echo "[dry-run] Would commit: \"chore (ui): add readme file for the ${COMPONENT} Component\""
  echo "[dry-run] Would stage: ${COMPONENT_DIR}"
  echo "[dry-run] Would commit: \"ui: Add logic, styles, and stories for the ${COMPONENT} component\""
else
  # Commit 1: readme
  git -C "$REPO_ROOT" add "${README_PATH}"
  git -C "$REPO_ROOT" commit -m "chore (ui): add readme file for the ${COMPONENT} Component"

  # Commit 2: logic, styles, and stories
  git -C "$REPO_ROOT" add "${COMPONENT_DIR}"
  git -C "$REPO_ROOT" commit -m "ui: Add logic, styles, and stories for the ${COMPONENT} component"
fi
