{
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "word-dash",
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "extra-files": [
        {
          "type": "json",
          "path": "frontend/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "frontend/package-lock.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "frontend/package-lock.json",
          "jsonpath": "$.packages[\"\"].version"
        }
      ]
    }
  }
}
