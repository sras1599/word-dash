{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug (in-memory)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "env": {
        "PORT": "8080",
        "WS_PORT": "8081",
        "CORS_ORIGIN": "http://localhost:5173"
      }
    },
    {
      "name": "Backend: Debug (Redis)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "env": {
        "PORT": "8080",
        "WS_PORT": "8081",
        "CORS_ORIGIN": "http://localhost:5173",
        "REDIS_URL": "redis://localhost:6379"
      }
    }
  ]
}
